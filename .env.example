# Required — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — override the default Gemini model if the pinned default is retired/renamed.
# Check current free-tier model names at https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional but recommended — unauthenticated GitHub Search API is limited to 10 req/min;
# a token with no scopes (public read-only) raises this to 30 req/min.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=
